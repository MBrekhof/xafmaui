<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="XafMaui.Views.DaySheetPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:dxg="clr-namespace:DevExpress.Maui.DataGrid;assembly=DevExpress.Maui.DataGrid"
    xmlns:vm="clr-namespace:XafMaui.ViewModels"
    Title="Day Sheet">

    <ContentPage.BindingContext>
        <vm:DaySheetViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,*,Auto" Padding="8">
        <!-- Date picker -->
        <dx:DateEdit
            Grid.Row="0"
            Date="{Binding SelectedDate}"
            LabelText="Date"
            Margin="0,0,0,8" />

        <!-- Time entries grid -->
        <dxg:DataGridView
            x:Name="dataGrid"
            Grid.Row="1"
            ItemsSource="{Binding TimeEntries}"
            IsPullToRefreshEnabled="True"
            IsRefreshing="{Binding IsRefreshing}"
            PullToRefreshCommand="{Binding RefreshCommand}"
            AllowEditRows="False"
            AllowDeleteRows="False"
            Tap="OnGridTap">
            <dxg:DataGridView.Columns>
                <dxg:TextColumn FieldName="ProjectName" Caption="Project" Width="*" MinWidth="100" />
                <dxg:TextColumn FieldName="ProjectTaskName" Caption="Task" Width="*" MinWidth="100" />
                <dxg:NumberColumn FieldName="Hours" Caption="Hrs" Width="60" />
            </dxg:DataGridView.Columns>
        </dxg:DataGridView>

        <!-- Bottom bar -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Padding="0,8,0,0">
            <Label Text="{Binding TotalHours, StringFormat='Total: {0:F1}h'}"
                   VerticalOptions="Center" FontAttributes="Bold" FontSize="16" />
            <dx:DXButton Grid.Column="1" Content="Add" Clicked="OnAddClicked" Margin="8,0" />
            <dx:DXButton Grid.Column="2" Content="Submit" Clicked="OnSubmitClicked" />
        </Grid>

        <!-- Detail bottom sheet -->
        <dx:BottomSheet x:Name="detailSheet"
                        Grid.Row="1"
                        HalfExpandedRatio="0.45"
                        AllowedState="HalfExpanded"
                        IsModal="True"
                        ShowGrabber="True">
            <Grid Padding="16" RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="12">
                <Label x:Name="sheetProjectLabel"
                       FontSize="18" FontAttributes="Bold" />
                <Label x:Name="sheetTaskLabel" Grid.Row="1"
                       FontSize="16" TextColor="Gray" />
                <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,24,Auto,Auto" ColumnSpacing="8">
                    <Label Text="Hours:" FontAttributes="Bold" VerticalOptions="Center" />
                    <Label x:Name="sheetHoursLabel" Grid.Column="1" VerticalOptions="Center" />
                    <Label Grid.Column="3" Text="Status:" FontAttributes="Bold" VerticalOptions="Center" />
                    <Label x:Name="sheetStatusLabel" Grid.Column="4" VerticalOptions="Center" />
                </Grid>
                <Label Grid.Row="3" Text="Notes" FontAttributes="Bold" FontSize="14" />
                <ScrollView Grid.Row="4">
                    <Label x:Name="sheetNoteLabel" FontSize="14" TextColor="Gray" />
                </ScrollView>
            </Grid>
        </dx:BottomSheet>
    </Grid>
</ContentPage>
